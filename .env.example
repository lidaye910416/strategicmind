# StrategicMind - Environment configuration example.
#
# Copy this file to `.env` and edit values for your deployment.
# All variables are optional; defaults are shown in comments.
#
#   cp .env.example .env
#   # then uncomment and edit the lines you need

# =====================================================================
# LLM Provider
# =====================================================================
# Default: ollama (fully local). Set to "bailian" to use Alibaba Cloud
# (requires LLM_API_KEY below) or "minimax" to use MiniMax M3.
# When LLM_PROVIDER is unset, the factory auto-detects based on which
# credentials are present: MINIMAX_API_KEY -> minimax, LLM_API_KEY ->
# bailian, else ollama.
#
# LLM_PROVIDER=ollama

# --- Ollama (default; no API key needed) ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=gemma4:e2b

# --- Bailian (Alibaba Cloud DashScope) ---
# LLM_API_KEY=your-bailian-api-key
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL_NAME=qwen-plus
# LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=4096
# LLM_TIMEOUT=120

# --- MiniMax (M3 highspeed, Anthropic-compatible API) ---
# The endpoint is at https://api.minimaxi.com/anthropic and accepts
# Anthropic Messages API requests. Any of these env vars can carry
# the key (first match wins):
#   MINIMAX_API_KEY, MiniMax_API_KEY, ANTHROPIC_API_KEY, LLM_API_KEY
# MINIMAX_API_KEY=your-minimax-key
# ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
# MiniMax_MODEL_NAME=MiniMax-M3
# LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=4096
# LLM_TIMEOUT=120

# =====================================================================
# Pipeline paths
# =====================================================================
# Directories for the API + pipeline orchestrator. The defaults point at
# <backend>/{uploads,data/reports,data/pipelines}; override only if you
# want them elsewhere (e.g. a shared volume).
#
# UPLOAD_FOLDER=./uploads
# REPORTS_DIR=./data/reports
# PIPELINE_CHECKPOINT_DIR=./data/pipelines

# =====================================================================
# Flask
# =====================================================================
# SECRET_KEY=change-me-in-production
# FLASK_DEBUG=true
# MAX_CONTENT_LENGTH=52428800
# HOST=0.0.0.0
# PORT=8000

# =====================================================================
# Zep Cloud (OPTIONAL - only if migrating from Zep)
# =====================================================================
# StrategicMind does NOT require Zep. If you are migrating an existing
# Zep-based system, you can still set these for legacy compatibility,
# but they are otherwise unused.
#
# GRAPH_STORE_PROVIDER=local
# ZEP_API_KEY=
# ZEP_URL=

# =====================================================================
# Development / Testing
# =====================================================================
# Override the LLM provider with a fully-qualified class path. Used by
# acceptance tests to swap in MockLLMProvider. NOT recommended in prod.
#
# STRATEGICMIND_LLM_OVERRIDE=backend.tests.mocks.mock_llm_provider.MockLLMProvider

# =====================================================================
# KG entity-type taxonomy (KG-OPT-P2 [P2-5-taxonomy-extensible])
# =====================================================================
# CSV 自定义实体类型白名单 — 覆盖默认 8 个 bottom 类型
# (Person, Organization, Location, Event, Concept, Product, Policy, Coalition)。
# 用于领域语料（法律、医疗、金融等），白名单外类型会被软降级到
# STRATEGICMIND_KG_FALLBACK_TYPE。未设置时使用默认 8 元组。
#
# STRATEGICMIND_KG_TYPE_TAXONOMY=Person,Organization,Location,Event,Concept,Product,Policy,Coalition

# 非白名单实体软降级到这个类型 — LLM 返回白名单外的 type 时（例如
# "Unknown" / "Other" / 新长尾类型）不丢弃，而是把 entity_type 降级为
# 此值并把原始 type 记到 attributes["original_entity_type"]。
# 未设置时默认 "Concept"。
#
# STRATEGICMIND_KG_FALLBACK_TYPE=Concept

# =====================================================================
# Simulation Loop Engine (Bug #2 fix)
# =====================================================================
# STRATEGICMIND_LOOP_ENGINE_V2=true|false (default false = v1)
# 设 true 走 v2 LoopEngine, 启用 4-slice LLM 注入 + 反馈循环闭合
# + LLM 同步返回 belief cascade (BeliefEffectProposal).
# 1 release 后 v1 SimulationLoop 路径删除, 移除此 env flag.
# 文档统一用 _V2 后缀 (config/manager.py:25, docs/features/simulation-realism.md §6.2/§9).
#
# STRATEGICMIND_LOOP_ENGINE_V2=false
